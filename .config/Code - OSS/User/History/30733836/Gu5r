##
## Makefile 
##

## Define compiler

CC	= gcc

## Define flags

CFLAGS	= -std=c99 -Wall -Wshadow -Wvla -g -pedantic -fstack-protector-strong --param ssp-buffer-size=1

## if you want to compile with the -O3 flag, comment the preceding CFLAGS and 
## uncomment the following CFLAGS

# CFLAGS	= -std=c99 -Wall -Wshadow -Werror -Wvla -O3 -pedantic -fstack-protector-strong --param ssp-buffer-size=1

## Build rule to build executable, by default, pa05 is build since it 
## is the label of the first rule

pa05: pa05.o answer05.o 
	$(CC) $(CFLAGS) pa05.o answer05.o -o pa05

## rule to test with argument option 0

test1: pa05
	./pa05 0 inputfile

## rule to test with argument option 1

test2: pa05
	./pa05 1 inputfile

test3: pa05
	./pa05

## rule to test all

test_all: test3 test1 test2

## rule to run valgrind

memory: pa05
	valgrind --log-file=log0.txt ./pa05 0 inputfile
	valgrind --log-file=log1.txt ./pa05 1 inputfile

## rule to clean up object files and executable so that you can rebuild

clean:	
	rm -f pa05.o answer05.o pa05

## rule to compile .c to .o

%.o: %.c
	$(CC) $(CFLAGS) -c $< 
